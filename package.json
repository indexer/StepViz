{
  "name": "stepviz",
  "private": true,
  "version": "0.0.0",
  "packageManager": "npm@11.6.2",
  "type": "module",
  "scripts": {
    "generate:summaries": "node scripts/generate-algorithm-summaries.mjs",
    "dev": "vite",
    "pretest": "npm run generate:summaries",
    "pretest:run": "npm run generate:summaries",
    "test": "vitest",
    "test:run": "vitest run",
    "pretypecheck": "npm run generate:summaries",
    "typecheck": "tsc -b",
    "lint": "eslint . --max-warnings=0",
    "check": "npm run lint && npm run typecheck && npm run test:run",
    "build": "npm run typecheck && vite build",
    "docker:build": "docker build -t stepviz .",
    "preview": "vite preview"
  },
  "dependencies": {
    "@tailwindcss/vite": "^4.2.2",
    "@tanstack/react-query": "^5.99.0",
    "prismjs": "^1.30.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-router-dom": "^7.14.1",
    "tailwindcss": "^4.2.2"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^24.12.2",
    "@types/prismjs": "^1.26.6",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "jsdom": "^29.0.2",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.58.0",
    "vite": "^8.0.4",
    "vitest": "^4.1.4"
  }
}
